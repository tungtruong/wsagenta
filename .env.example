OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4.1-mini
ALLOWED_OPENAI_MODELS=gpt-4.1-mini,gpt-4.1,gpt-4o-mini
DEFAULT_RESEARCH_DEPTH=basic
CHAT_STATE_FILE=./data/chat-state.json
MAX_TURNS=20
AUTO_CONTINUE_ON_MAX_TURNS=true
MAX_RUN_SEGMENTS=3
WORKSPACE_DIR=.
ENABLE_SHELL_TOOL=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ENABLE_TAVILY_SEARCH_TOOL=true
TAVILY_API_KEY=your_tavily_api_key_here
ENABLE_ZYTE_WEB_TOOL=true
ZYTE_API_KEY=your_zyte_api_key_here
VERBOSE_AGENT_LOG=true
